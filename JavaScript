<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FoodBridge | NGO Food Supply Network - Dehradun</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="style.css">
</head>
<body>

<!-- LOGIN PAGE -->
<div id="login-page" class="page active">
    <!-- Login content same as before -->
    <div class="login-bg">
        <div class="login-bg-orb orb1"></div>
        <div class="login-bg-orb orb2"></div>
        <div class="login-bg-orb orb3"></div>
    </div>
    <div class="login-split">
        <div class="login-left">
            <div class="login-brand">
                <div class="brand-icon">🌾</div>
                <span class="brand-name">FoodBridge</span>
            </div>
            <div class="login-hero">
                <h1 class="login-headline">Connecting<br><em>Surplus</em><br>to Need.</h1>
                <p class="login-subtext">An intelligent food distribution network using priority-based greedy algorithms to feed those who need it most.</p>
            </div>
            <div class="login-stats">
                <div class="login-stat"><span class="stat-num">8+</span><span class="stat-label">NGO Partners</span></div>
                <div class="login-stat"><span class="stat-num">500kg</span><span class="stat-label">Daily Supply</span></div>
                <div class="login-stat"><span class="stat-num">O(n log n)</span><span class="stat-label">Algorithm</span></div>
            </div>
        </div>
        <div class="login-right">
            <div class="login-card">
                <div class="login-card-header">
                    <h2>Welcome back</h2>
                    <p>Sign in to manage food allocations</p>
                </div>
                <div class="role-selector">
                    <button class="role-btn active" onclick="selectRole('admin',this)">🏛️ Admin</button>
                    <button class="role-btn" onclick="selectRole('hostel',this)">🏠 Hostel</button>
                    <button class="role-btn" onclick="selectRole('ngo',this)">🤝 NGO</button>
                </div>
                <div class="login-form">
                    <div class="form-field">
                        <label>Email Address</label>
                        <div class="input-wrap">
                            <span class="input-icon">✉</span>
                            <input type="email" id="login-email" placeholder="you@organization.org" value="admin@foodbridge.org">
                        </div>
                    </div>
                    <div class="form-field">
                        <label>Password</label>
                        <div class="input-wrap">
                            <span class="input-icon">🔒</span>
                            <input type="password" id="login-password" placeholder="••••••••" value="admin123">
                            <button class="toggle-pwd" onclick="togglePassword()">👁</button>
                        </div>
                    </div>
                    <div class="login-options">
                        <label class="checkbox-label"><input type="checkbox" checked> Remember me</label>
                        <a href="#" class="forgot-link">Forgot password?</a>
                    </div>
                    <button class="login-btn" onclick="handleLogin()"><span>Sign In</span><span class="btn-arrow">→</span></button>
                    <div class="login-divider"><span>Quick Demo Access</span></div>
                    <div class="demo-creds">
                        <div class="demo-cred" onclick="fillDemo('admin@foodbridge.org','admin123')">
                            <span>🏛️ Admin</span><code>admin@foodbridge.org</code>
                        </div>
                        <div class="demo-cred" onclick="fillDemo('hostel@mess.edu','hostel123')">
                            <span>🏠 Hostel</span><code>hostel@mess.edu</code>
                        </div>
                        <div class="demo-cred" onclick="fillDemo('ngo@help.org','ngo123')">
                            <span>🤝 NGO</span><code>ngo@help.org</code>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MAIN DASHBOARD -->
<div id="main-page" class="page">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-brand"><div class="brand-icon-sm">🌾</div><span>FoodBridge</span></div>
            <button class="sidebar-toggle" onclick="toggleSidebar()">☰</button>
        </div>
        <div class="sidebar-user">
            <div class="user-avatar" id="user-avatar">A</div>
            <div class="user-info">
                <div class="user-name" id="user-name">Admin User</div>
                <div class="user-role" id="user-role">System Administrator</div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <button class="nav-item active" data-tab="dashboard" onclick="switchTab('dashboard',this)"><span class="nav-icon">📊</span><span class="nav-label">Dashboard</span></button>
            <button class="nav-item" data-tab="ngo" onclick="switchTab('ngo',this)"><span class="nav-icon">🏢</span><span class="nav-label">NGO Management</span></button>
            <button class="nav-item" data-tab="food" onclick="switchTab('food',this)"><span class="nav-icon">🍱</span><span class="nav-label">Food Donations</span></button>
            <button class="nav-item" data-tab="allocation" onclick="switchTab('allocation',this)"><span class="nav-icon">⚡</span><span class="nav-label">Allocation Engine</span></button>
            <button class="nav-item" data-tab="reports" onclick="switchTab('reports',this)"><span class="nav-icon">📋</span><span class="nav-label">Reports</span></button>
            <button class="nav-item" data-tab="complexity" onclick="switchTab('complexity',this)"><span class="nav-icon">📈</span><span class="nav-label">Complexity Analysis</span></button>
        </nav>
        <div class="sidebar-footer">
            <button class="logout-btn" onclick="handleLogout()">↩ Sign Out</button>
        </div>
    </aside>

    <main class="main-content" id="main-content">
        <div class="topbar">
            <div class="topbar-left">
                <h2 class="page-title" id="page-title">Dashboard</h2>
                <div class="breadcrumb" id="breadcrumb">Home / Dashboard</div>
            </div>
            <div class="topbar-right">
                <div class="live-indicator"><span class="pulse-dot"></span> Live</div>
                <div class="food-stock-badge">🍱 Stock: <strong id="topbar-stock">500</strong> kg</div>
                <div class="time-display" id="time-display"></div>
            </div>
        </div>

        <!-- DASHBOARD -->
        <div id="dashboard-tab" class="tab-pane active">
            <div class="dashboard-grid">
                <div class="stat-card card-green"><div class="stat-card-icon">🏢</div><div class="stat-card-body"><div class="stat-card-num" id="dash-ngo-count">0</div><div class="stat-card-label">Registered NGOs</div></div><div class="stat-card-trend">Active partners</div></div>
                <div class="stat-card card-amber"><div class="stat-card-icon">🍱</div><div class="stat-card-body"><div class="stat-card-num" id="dash-food-stock">500</div><div class="stat-card-label">Food Stock (kg)</div></div><div class="stat-card-trend">Available now</div></div>
                <div class="stat-card card-blue"><div class="stat-card-icon">👥</div><div class="stat-card-body"><div class="stat-card-num" id="dash-beneficiaries">0</div><div class="stat-card-label">Total Beneficiaries</div></div><div class="stat-card-trend">Across all NGOs</div></div>
                <div class="stat-card card-purple"><div class="stat-card-icon">⚡</div><div class="stat-card-body"><div class="stat-card-num" id="dash-allocations">0</div><div class="stat-card-label">Allocations Run</div></div><div class="stat-card-trend">Total sessions</div></div>
            </div>
            <div class="dashboard-lower">
                <div class="panel">
                    <div class="panel-header"><h3>Top Priority NGOs</h3><button class="mini-btn" onclick="switchTab('ngo',document.querySelector('[data-tab=ngo]'))">View All →</button></div>
                    <div id="dash-priority-list" class="priority-list"></div>
                </div>
                <div class="panel">
                    <div class="panel-header"><h3>Quick Actions</h3></div>
                    <div class="quick-actions">
                        <button class="qa-btn" onclick="switchTab('food',document.querySelector('[data-tab=food]'));showAddFoodForm()"><span>🍱</span><span>Add Donation</span></button>
                        <button class="qa-btn" onclick="switchTab('ngo',document.querySelector('[data-tab=ngo]'));showAddNGOForm()"><span>➕</span><span>Add NGO</span></button>
                        <button class="qa-btn" onclick="switchTab('allocation',document.querySelector('[data-tab=allocation]'))"><span>⚡</span><span>Run Allocation</span></button>
                        <button class="qa-btn" onclick="switchTab('reports',document.querySelector('[data-tab=reports]'));generateReport()"><span>📋</span><span>Full Report</span></button>
                    </div>
                </div>
            </div>
        </div>

        <!-- NGO MANAGEMENT -->
        <div id="ngo-tab" class="tab-pane">
            <div class="pane-toolbar">
                <div class="toolbar-left">
                    <button class="action-btn btn-amber" onclick="calculatePriorities()">🎯 Calculate Priorities</button>
                    <div class="search-wrap"><span>🔍</span><input type="text" id="search-ngo" placeholder="Search NGOs..." onkeyup="filterNGOs(this.value)"></div>
                </div>
                <button class="action-btn btn-primary" onclick="showAddNGOForm()">➕ Add NGO</button>
            </div>
            <div class="data-table-wrap">
                <table class="data-table">
                    <thead><tr><th onclick="sortByColumn('id')">ID ↕</th><th onclick="sortByColumn('name')">NGO Name ↕</th><th onclick="sortByColumn('urgency')">Urgency ↕</th><th onclick="sortByColumn('beneficiaries')">Beneficiaries ↕</th><th onclick="sortByColumn('quantity')">Requested (kg) ↕</th><th onclick="sortByColumn('priorityScore')">Priority Score ↕</th><th>Actions</th></tr></thead>
                    <tbody id="ngo-tbody"><tr><td colspan="7" class="empty-row">Loading NGOs...</td></tr></tbody>
                </table>
            </div>
            
            <!-- MAP INTEGRATED HERE - NICHE DIKHEGA -->
            <div class="map-integrated-section">
                <div class="panel">
                    <div class="panel-header">
                        <h3>📍 NGOs on Map - Dehradun Clement Town</h3>
                        <div class="map-legend">
                            <span class="legend-item"><span class="legend-color" style="background:#9b59b6;"></span> New</span>
                            <span class="legend-item"><span class="legend-color" style="background:#e74c3c;"></span> High</span>
                            <span class="legend-item"><span class="legend-color" style="background:#f39c12;"></span> Medium</span>
                            <span class="legend-item"><span class="legend-color" style="background:#2ecc71;"></span> Low-Med</span>
                            <span class="legend-item"><span class="legend-color" style="background:#3498db;"></span> Low</span>
                        </div>
                        <button class="mini-btn" onclick="refreshMap()">🔄 Refresh</button>
                    </div>
                    <div id="ngo-map" class="map-container"></div>
                    <div id="ngo-detail-panel" class="ngo-detail-panel" style="display:none;">
                        <!-- NGO details will be injected here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- FOOD DONATIONS -->
        <div id="food-tab" class="tab-pane">
            <div class="food-hero-banner">
                <div class="food-hero-left">
                    <div class="food-hero-label">Current Food Stock</div>
                    <div class="food-hero-value"><span id="food-stock-display">500</span> <span class="food-unit">kg</span></div>
                    <div class="food-hero-sub">Available for allocation to NGOs</div>
                </div>
                <button class="action-btn btn-primary btn-lg" onclick="showAddFoodForm()">➕ Add Food Donation</button>
            </div>
            <div class="panel">
                <div class="panel-header"><h3>Donation History</h3><span class="badge" id="donation-count">0 entries</span></div>
                <div class="data-table-wrap">
                    <table class="data-table">
                        <thead><tr><th>Date & Time</th><th>Supplier</th><th>Food Type</th><th>Quantity (kg)</th><th>Status</th></tr></thead>
                        <tbody id="donation-tbody"><tr><td colspan="5" class="empty-row">No donations recorded yet</td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ALLOCATION ENGINE -->
        <div id="allocation-tab" class="tab-pane">
            <div class="allocation-config">
                <div class="config-card">
                    <div class="config-label">Sorting Algorithm</div>
                    <select id="sort-algorithm" class="styled-select">
                        <option value="0">⚡ QuickSort — O(n log n) avg</option>
                        <option value="1">🔗 MergeSort — O(n log n) stable</option>
                        <option value="2">🏔 HeapSort — O(n log n) in-place</option>
                        <option value="3">🫧 BubbleSort — O(n²) educational</option>
                        <option value="4">🎯 SelectionSort — O(n²) educational</option>
                        <option value="5">📥 InsertionSort — O(n²) educational</option>
                    </select>
                </div>
                <div class="config-card">
                    <div class="config-label">Food Stock to Allocate (kg)</div>
                    <input type="number" id="allocation-food-stock" class="styled-input" value="500">
                </div>
                <button class="action-btn btn-success btn-lg run-btn" onclick="runAllocation()">⚡ Run Greedy Allocation</button>
            </div>
            <div id="allocation-summary-bar" class="allocation-summary-bar" style="display:none">
                <div class="summary-item"><span class="summary-label">Algorithm</span><span class="summary-val" id="sum-algorithm">—</span></div>
                <div class="summary-item"><span class="summary-label">Time Complexity</span><span class="summary-val mono" id="sum-time">—</span></div>
                <div class="summary-item"><span class="summary-label">Total Allocated</span><span class="summary-val" id="sum-allocated">—</span></div>
                <div class="summary-item"><span class="summary-label">Remaining Stock</span><span class="summary-val" id="sum-remaining">—</span></div>
                <div class="summary-item"><span class="summary-label">Efficiency</span><span class="summary-val" id="sum-efficiency">—</span></div>
            </div>
            <div class="panel">
                <div class="panel-header"><h3>Allocation Results</h3></div>
                <div class="data-table-wrap">
                    <table class="data-table">
                        <thead><tr><th>Rank</th><th>NGO Name</th><th>Priority Score</th><th>Requested (kg)</th><th>Allocated (kg)</th><th>Status</th></tr></thead>
                        <tbody id="allocation-tbody"><tr><td colspan="6" class="empty-row">Run allocation to see results</td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- REPORTS -->
        <div id="reports-tab" class="tab-pane">
            <div class="pane-toolbar">
                <div></div>
                <div style="display:flex;gap:10px">
                    <button class="action-btn btn-amber" onclick="generateReport()">📄 Generate Report</button>
                    <button class="action-btn btn-primary" onclick="printReport()">🖨 Print</button>
                </div>
            </div>
            <div class="report-container">
                <div id="report-content" class="report-content">
                    <div class="report-placeholder"><div style="font-size:64px">📋</div><h3>No Report Generated</h3><p>Click "Generate Report" to create a full system report</p></div>
                </div>
            </div>
        </div>

        <!-- COMPLEXITY ANALYSIS -->
        <div id="complexity-tab" class="tab-pane">
            <div class="complexity-header"><h3>Algorithm Complexity Analysis</h3><p>Design & Analysis of Algorithms — DAA Project</p></div>
            <div class="complexity-cards">
                <div class="cx-card cx-green"><div class="cx-title">Priority Calculation (C++)</div><div class="cx-badge">O(n)</div><pre class="cx-code">for each NGO:
  score = (urgency × 60) +
          (beneficiaries × 40)
Time:  O(n)
Space: O(1)</pre></div>
                <div class="cx-card cx-blue"><div class="cx-title">Sorting Algorithms (C++)</div><div class="cx-badge">O(n log n)</div><pre class="cx-code">QuickSort:  O(n log n) avg
MergeSort:  O(n log n) stable
HeapSort:   O(n log n) in-place
BubbleSort: O(n²)
SelectSort: O(n²)
InsertSort: O(n²)</pre></div>
                <div class="cx-card cx-amber"><div class="cx-title">Greedy Allocation (C++)</div><div class="cx-badge">O(n)</div><pre class="cx-code">for each NGO (sorted desc):
  if food >= requested:
    allocate fully
  elif food > 0:
    allocate partial
Time:  O(n)
Space: O(1)</pre></div>
                <div class="cx-card cx-purple"><div class="cx-title">Frontend Algorithms (JS)</div><div class="cx-badge">O(n log n)</div><pre class="cx-code">Table Sort:    O(n log n)
Filter/Search: O(n)
Statistics:    O(n)
Binary Search: O(log n)
Priority Map:  O(1)</pre></div>
            </div>
            <div class="overall-complexity">
                <div class="oc-label">Overall System Complexity</div>
                <div class="oc-values">
                    <div class="oc-val"><span class="oc-key">Time</span><span class="oc-num mono">O(n log n)</span></div>
                    <div class="oc-divider"></div>
                    <div class="oc-val"><span class="oc-key">Space</span><span class="oc-num mono">O(n)</span></div>
                    <div class="oc-divider"></div>
                    <div class="oc-val"><span class="oc-key">Backend</span><span class="oc-num">C++ (httplib)</span></div>
                    <div class="oc-divider"></div>
                    <div class="oc-val"><span class="oc-key">Frontend</span><span class="oc-num">Vanilla JS</span></div>
                </div>
            </div>
            <div id="live-complexity" class="live-complexity" style="display:none">
                <div class="panel-header"><h3>Last Allocation — Live Analysis</h3></div>
                <pre id="live-complexity-content" class="cx-code big"></pre>
            </div>
        </div>
    </main>
</div>

<!-- MODALS -->
<div id="modal-add-ngo" class="modal-overlay" style="display:none">
    <div class="modal-box">
        <div class="modal-header"><h3>➕ Register New NGO</h3><button class="modal-close" onclick="hideAddNGOForm()">✕</button></div>
        <div class="modal-body">
            <div class="modal-form-grid">
                <div class="form-field full-width"><label>NGO Name *</label><input type="text" id="ngo-name" placeholder="e.g., Helping Hands Foundation"></div>
                <div class="form-field"><label>Urgency Level (1–10)</label><input type="number" id="ngo-urgency" min="1" max="10" value="5"></div>
                <div class="form-field"><label>Beneficiaries</label><input type="number" id="ngo-beneficiaries" min="1" value="100"></div>
                <div class="form-field full-width"><label>Food Required (kg)</label><input type="number" id="ngo-quantity" min="1" value="50"></div>
            </div>
        </div>
        <div class="modal-footer"><button class="action-btn btn-ghost" onclick="hideAddNGOForm()">Cancel</button><button class="action-btn btn-primary" onclick="addNGO()">Register NGO</button></div>
    </div>
</div>

<div id="modal-add-food" class="modal-overlay" style="display:none">
    <div class="modal-box">
        <div class="modal-header"><h3>🍱 Add Food Donation</h3><button class="modal-close" onclick="hideAddFoodForm()">✕</button></div>
        <div class="modal-body">
            <div class="modal-form-grid">
                <div class="form-field"><label>Supplier / Hostel Name *</label><input type="text" id="supplier-name" placeholder="e.g., Hostel A Mess"></div>
                <div class="form-field"><label>Food Type</label><input type="text" id="food-type" placeholder="e.g., Cooked Rice, Vegetables"></div>
                <div class="form-field full-width"><label>Quantity (kg) *</label><input type="number" id="food-quantity" min="1" value="50"></div>
            </div>
        </div>
        <div class="modal-footer"><button class="action-btn btn-ghost" onclick="hideAddFoodForm()">Cancel</button><button class="action-btn btn-success" onclick="addFoodDonation()">Add Donation</button></div>
    </div>
</div>

<div id="toast-container" class="toast-container"></div>

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="app.js"></script>
</body>
</html>